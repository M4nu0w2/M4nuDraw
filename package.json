{
  "name": "m4nudraw-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @m4nudraw/client\" \"npm run dev -w @m4nudraw/server\"",
    "build": "npm run build --workspaces",
    "build:client": "npm run build -w @m4nudraw/shared && npm run build -w @m4nudraw/client",
    "lint": "npm run lint --workspaces",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  }
}
